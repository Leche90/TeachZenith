# Copy this file to backend/.env and fill in. Never commit the real .env.

# --- Required ---
# On local WSL use the socket form (no host, no password):
DATABASE_URL=postgres:///teachzenith
PORT=4000
NODE_ENV=development

# --- Optional now; needed for matching / ingestion / worker later ---
REDIS_URL=redis://localhost:6379
ANTHROPIC_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JSEARCH_API_KEY=
JSEARCH_HOST=api.openwebninja.com

# Freshness window in days (tunable without a migration)
FRESHNESS_DAYS=14
