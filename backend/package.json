    "express": "4.22.2",
    "ioredis": "5.11.1",
    "pg": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.23",
    "@types/node": "22.9.0",
    "@types/pg": "8.20.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
